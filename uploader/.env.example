# ──────────────────────────────────────────────────────────────────────────
#  Lead Pusher — uploader backend config (env only). Copy to .env and fill in.
#  Everything is namespaced by VENDOR_FOLDER_NAME (queue, store prefix, redis keys).
# ──────────────────────────────────────────────────────────────────────────

# Which lending partner this deployment serves. Drives queue name, store prefix,
# redis namespace, and which external-api/{partner} module is used.
VENDOR_FOLDER_NAME=creditlinks
# Optional override of the partner module if it differs from the vendor folder.
PARTNER=creditlinks

# ── XAMPP / htdocs file store (replaces S3) ───────────────────────────────
# Absolute path inside XAMPP's htdocs where files are written, and the public
# Apache URL that serves that same folder.
#   macOS XAMPP:   /Applications/XAMPP/xamppfiles/htdocs/leadpusher
#   Linux LAMPP:   /opt/lampp/htdocs/leadpusher
#   Windows:       C:\xampp\htdocs\leadpusher
HTDOCS_BASE_PATH=/Applications/XAMPP/xamppfiles/htdocs/leadpusher
FILE_BASE_URL=http://localhost/leadpusher

# Local scratch dir where the downloader copies files for streaming reads.
LOCAL_DOWNLOAD_DIR=downloads

# ── Redis (DEDICATED, isolated instance — see docker-compose.yml) ─────────
# Runs on port 6380 so it is separate from any other Redis on this machine and
# never shows in another tool's portal. (Native alt: run a 2nd redis on 6380.)
REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=
REDIS_DB=0

# ── RabbitMQ (DEDICATED, isolated instance — see docker-compose.yml) ───────
# Dedicated broker on :5673 with its own user + vhost "leadpusher", so this
# project's queues never appear in any other RabbitMQ management portal.
# Management UI for THIS broker only: http://localhost:15673 (leadpusher/leadpusher)
RABBITMQ_URL=amqp://leadpusher:leadpusher@localhost:5673/leadpusher

# ── HTTP API ──────────────────────────────────────────────────────────────
PORT=4000
UPLOAD_TMP_DIR=tmp-uploads
MAX_UPLOAD_BYTES=209715200
# If set, the upload endpoint requires header `x-api-token: <value>`.
UPLOAD_API_TOKEN=
# CORS origin for the frontend dev server (default *).
CORS_ORIGIN=http://localhost:5173

# ── Pipeline behaviour ────────────────────────────────────────────────────
# Summary-file flush size (rows per summary batch).
CHUNK_SIZE=500
# Defaults used when the frontend doesn't send per-upload control values.
DEFAULT_BATCH_SIZE=100
DEFAULT_DELAY_BETWEEN_BATCHES=1000
# Consumer throughput.
CONCURRENCY=5
CONSUMER_PREFETCH=10
# Flush a partial summary batch after this many ms of idle.
IDLE_FLUSH_MS=15000

# ── Retry / backoff (429/500/502/503/504/network) ─────────────────────────
MAX_ATTEMPTS=5
RETRY_BASE_DELAY_MS=2000
RETRY_MAX_DELAY_MS=60000

# ── Worker poll intervals (ms) ────────────────────────────────────────────
WATCH_INTERVAL_MS=10000
DOWNLOAD_INTERVAL_MS=5000
PRODUCE_INTERVAL_MS=5000

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── CreditLinks Partner API v2.13 (apikey header auth) ────────────────────
# UAT base:  https://loannet.in:8000
# PROD base: https://l.creditlinks.in:8000
CREDITLINKS_BASE_URL=https://loannet.in:8000
# Personal partner APIKEY from the Partner Portal (Digital Integration).
CREDITLINKS_API_KEY=xxxxxxxx-xxxx-xxxx-xxxxxxxxxxxx
CREDITLINKS_TIMEOUT_MS=20000
# consumerConsentIp used when a row doesn't carry one.
CREDITLINKS_DEFAULT_CONSENT_IP=0.0.0.0
# create-lead waitForAllOffers: 0/unset, 1 (wait up to 180s), 2 (don't wait).
CREDITLINKS_WAIT_FOR_ALL_OFFERS=0

# ── CreditMitra partner credentials (HMAC signing reference/template) ──────
CREDITMITRA_BASE_URL=https://api.creditmitra.example
CREDITMITRA_API_KEY=replace-me
CREDITMITRA_API_SECRET=replace-me
CREDITMITRA_TIMEOUT_MS=15000
